# n8n Automation Agent - Environment Variables
# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun

# AI Provider (en az birini doldurun)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
OPENAI_API_KEY=sk-xxxxx

# n8n Instance (opsiyonel - deploy icin gerekli)
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# n8n Self-Hosted (Modal uzerinde n8n calistirmak icin)
N8N_USER=admin
N8N_PASSWORD=securepassword123
N8N_ENCRYPTION_KEY=change-me-random-32-char-string

# Modal.com (otomatik - modal setup ile ayarlanir)
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
